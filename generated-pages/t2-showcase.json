{
  "version": 1,
  "theme": "studio",
  "behaviors": [{ "component": "pointer-overlay", "props": { "variant": "cursor" } }],
  "sections": [
    {
      "id": "opening",
      "component": "section.hero",
      "props": { "eyebrow": "Studio", "title": "Built to move", "body": "A deliberately small studio bringing product thinking to what comes next.", "ctaLabel": "Start a chat", "layout": "editorial" },
