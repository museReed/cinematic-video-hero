    },
    {
      "id": "rail",
      "component": "section.marquee",
      "props": { "content": "text", "text": "Every frame counts", "speed": "normal", "rows": 2 }
    },
    {
      "id": "features",
      "component": "section.feature-grid",
      "props": { "badge": "Core Features", "title": "Built for Speed & Quality", "subtitle": "Everything from idea to image" },
      "children": [
        { "component": "section.feature-card", "props": { "variant": "prompt", "title": "Smart Prompt Suggestions", "body": "Enhance any prompt in one tap." } },
        { "component": "section.feature-card", "props": { "variant": "api", "title": "API Access", "body": "Connect the studio to your stack." } },
        { "component": "section.feature-card", "props": { "variant": "library", "title": "Project Library", "body": "Search every asset you make." } }
