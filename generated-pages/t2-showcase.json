    {
      "id": "closing",
      "component": "section.footer",
      "props": {
        "ctaLabel": "Start a chat",
        "columns": [
          { "heading": "Explore", "links": [{ "label": "Work", "href": "#work" }, { "label": "About", "href": "#about" }] },
          { "heading": "Social", "links": [{ "label": "x.com", "href": "https://x.com" }, { "label": "LinkedIn", "href": "https://linkedin.com" }] }
        ],
        "company": "Vortex Studio Limited",
        "location": "Austin, USA",
        "bottomCtaLabel": "Start a chat"
      }
    }
  ]
